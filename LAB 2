#include <stdio.h>
int main() {
    int choice;
    float a, b;
    do {
        printf("\n1.Add  2.Sub  3.Mul  4.Div  5.Exit\nChoice: ");
        scanf("%d", &choice);
        if (choice >= 1 && choice <= 4) {
            printf("Enter two numbers: ");
            scanf("%f %f", &a, &b);
        }
        switch (choice) {
            case 1: printf("Result = %.2f\n", a + b); break;
            case 2: printf("Result = %.2f\n", a - b); break;
            case 3: printf("Result = %.2f\n", a * b); break;
            case 4: b ? printf("Result = %.2f\n", a / b) : printf("Error: Division by zero!\n"); break;
            case 5: printf("Goodbye!\n"); break;
            default: printf("Invalid choice!\n");
        }
    } while (choice != 5);
    return 0;
}
